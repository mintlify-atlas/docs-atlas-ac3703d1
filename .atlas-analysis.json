  "keyFeatures": [
    "Multi-tenant school management (super-admin creates and manages schools)",
    "Role-based access control: super-admin, director, teacher, student, parent",
    "Academic period and evaluation period management",
    "Course and section (paralelo) management with schedule assignment",
    "Teacher class dashboard with attendance, agenda/tasks, grade book, and anecdotario",
    "Student portal with schedule, subjects, pending tasks, library, and exams",
    "Parent portal to track children's grades, attendance, agenda, and anecdotes",
    "Circular (announcements) system with targeted delivery by role",
    "Student enrollment management per academic period",
    "File upload support for task submissions and agenda attachments",
    "Secure session storage with JWT Bearer token authentication",
    "Dio HTTP client with automatic 401 redirect and Bearer token injection"
  ],
